---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="LiAlvaro Apparel — Custom Printing, Los Angeles"
  exactTitle
  description="LiAlvaro Apparel — Los Angeles' premier custom apparel printer. Screen printing, DTG, DTF, embroidery. No minimums. Same-day service. Call (310) 904-2655."
  keywords="custom t-shirts Los Angeles, screen printing LA, DTG printing, custom embroidery, custom hoodies, same day printing Los Angeles"
  quoteCta="modal"
  faqHref="#faq"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    slot="head"
    href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;500;600;700&family=Manrope:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

<div class="modal-overlay" id="modalOverlay" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
  <div class="modal" id="modal">

    <div id="modalForm">
      <div class="modal-header">
        <div class="modal-header-text">
          <div class="modal-eyebrow">Free Quote</div>
          <div class="modal-title" id="modalTitle">Let's get you a quote</div>
          <div class="modal-sub">We'll respond within 1 business hour.</div>
        </div>
        <button class="modal-close" id="modalClose" aria-label="Close">✕</button>
      </div>

      <div class="modal-body">
        <div class="form-label" style="margin-bottom:10px;">Select a service</div>
        <div class="service-picker" id="servicePicker">
          <div class="service-opt selected" data-service="Screen Printing">
            <span class="service-opt-icon">🖨️</span>
            <span class="service-opt-name">Screen Printing</span>
          </div>
          <div class="service-opt" data-service="Direct to Garment">
            <span class="service-opt-icon">🎨</span>
            <span class="service-opt-name">DTG Printing</span>
          </div>
          <div class="service-opt" data-service="Direct to Film">
            <span class="service-opt-icon">🎞️</span>
            <span class="service-opt-name">Direct to Film</span>
          </div>
          <div class="service-opt" data-service="Embroidery">
            <span class="service-opt-icon">🪡</span>
            <span class="service-opt-name">Embroidery</span>
          </div>
        </div>

        <div class="form-divider">Your details</div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="fname">First name</label>
            <input type="text" id="fname" class="form-input" placeholder="Alex">
          </div>
          <div class="form-group">
            <label class="form-label" for="lname">Last name</label>
            <input type="text" id="lname" class="form-input" placeholder="Johnson">
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Email address</label>
          <input type="email" id="email" class="form-input" placeholder="alex@example.com">
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="phone">Phone (optional)</label>
            <input type="tel" id="phone" class="form-input" placeholder="(310) 000-0000">
          </div>
          <div class="form-group">
            <label class="form-label" for="qty">Quantity</label>
            <select id="qty" class="form-select">
              <option>1–11 pieces</option>
              <option selected>12–24 pieces</option>
              <option>25–49 pieces</option>
              <option>50–99 pieces</option>
              <option>100+ pieces</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="details">Design details / notes</label>
          <textarea id="details" class="form-textarea" placeholder="Describe your design, garment type, colors, or any special requirements…"></textarea>
        </div>

        <button class="modal-submit" id="modalSubmit">Send My Quote Request →</button>
        <div class="modal-guarantee">🔒 &nbsp;No spam. No hidden fees. Just a fast, honest quote.</div>
      </div>
    </div>

    <div class="modal-success" id="modalSuccess">
      <div class="success-icon">🎉</div>
      <div class="success-title">Quote request received!</div>
      <div class="success-sub">We'll have a personalized quote in your inbox within 1 business hour. For urgent orders, call us at <a href="tel:3109042655" style="color:var(--orange);font-weight:700;">(310) 904-2655</a>.</div>
      <button class="btn-success-close" id="successClose">Done</button>
    </div>

  </div>
</div>

<section class="hero">
  <div class="hero-glow"></div>
  <div class="container">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      Los Angeles' Premier Custom Apparel Printer
    </div>
    <h1>Custom Printed <span>T-shirts,</span><br>Hoodies, Hats &amp; More.</h1>
    <p class="hero-sub">Professional print quality, lightning-fast turnaround, and designs that leave a lasting impression — with no minimums.</p>
    <div class="hero-actions">
      <button class="btn-primary" data-quote-trigger onclick="openModal()">Get Your Free Quote →</button>
      <a href="tel:3109042655" class="btn-secondary">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M3.7 1C3.3 1 2.5 1.3 1.9 2L1 3c-.7.7-1 2 .3 4 .7 1.2 1.7 2.6 3.1 4s2.8 2.4 4 3.1c2 1.3 3.3 1 4 .3l1-1c.7-.7 1-1.5 1-1.9 0-.2-.2-.5-.5-.7L12 9.5c-.3-.2-.6-.3-.8-.2l-1.3.4c-.3.1-.6 0-.8-.2L7.5 8l-1.5-1.6c-.2-.2-.3-.5-.2-.8L6.2 4.4c.1-.2 0-.5-.2-.8L4.4 1.5C4.2 1.2 3.9 1 3.7 1z"/></svg>
        Call (310) 904-2655
      </a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="stat-val">No<span> Min.</span></div>
        <div class="stat-label">No minimum order</div>
      </div>
      <div class="hero-stat">
        <div class="stat-val">Same<span>-Day</span></div>
        <div class="stat-label">Available in LA</div>
      </div>
      <div class="hero-stat">
        <div class="stat-val">24<span>/7</span></div>
        <div class="stat-label">Team support</div>
      </div>
      <div class="hero-stat">
        <div class="stat-val">4<span> Methods</span></div>
        <div class="stat-label">Printing options</div>
      </div>
    </div>
  </div>
</section>

<section class="services-section" id="services">
  <div class="container">
    <div class="services-header reveal">
      <div class="eyebrow">Print Services</div>
      <h2 class="section-title">Every print method,<br>under one roof.</h2>
      <p class="section-sub">From single shirts to large-scale production runs — we have the right process for your project.</p>
    </div>

    <div class="services-grid">
      <div class="service-card service-card-silkscreen-bg reveal">
        <div class="service-tag">Most Popular</div>
        <div class="service-name">Silkscreen Printing</div>
        <div class="service-desc">The gold standard for bulk apparel. Crisp, durable ink applied through a mesh screen delivers vivid, long-lasting colors at the best price-per-piece for larger quantities.</div>
        <button class="service-link" onclick="openModal('Screen Printing')">Get screen printing →</button>
      </div>

      <div class="service-card service-card-dtg-bg reveal">
        <div class="service-tag">No Minimums</div>
        <div class="service-name">Direct To Garment</div>
        <div class="service-desc">Vibrant, photo-realistic graphics printed directly onto your garment. Perfect for complex, full-color designs with no setup fees and no minimums.</div>
        <button class="service-link" onclick="openModal('Direct to Garment')">Print with DTG →</button>
      </div>

      <div class="service-card service-card-dtf-bg reveal" style="transition-delay:0.08s">
        <div class="service-tag">Best Durability</div>
        <div class="service-name">Direct To Film</div>
        <div class="service-desc">Our DTF service produces top-quality prints that bond to virtually any fabric. Exceptional durability and color vibrancy that holds up wash after wash.</div>
        <button class="service-link" onclick="openModal('Direct to Film')">Start DTF printing →</button>
      </div>

      <div class="service-card service-card-embroidery-bg reveal" style="transition-delay:0.16s">
        <div class="service-tag">Premium Finish</div>
        <div class="service-name">Custom Embroidery</div>
        <div class="service-desc">Elevate your brand with professional, tactile stitching. Our skilled artisans bring your vision to life on hats, polos, jackets, and premium outerwear.</div>
        <button class="service-link" onclick="openModal('Embroidery')">Get embroidery →</button>
      </div>
    </div>
  </div>
</section>

<section class="about-section" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="reveal">
        <div class="about-label"><span>Our Story</span></div>
        <h2 class="about-title">We're not just another print shop.</h2>
        <p class="about-body">We started LiAlvaro Apparel with a simple goal: to make premium custom printing accessible to everyone. Forget complicated processes and hidden fees. We're open about everything, dedicated to ethical practices, and always just a phone call away.</p>

        <div class="about-features">
          <div class="about-feature">
            <div class="feature-check">
              <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 6L5 9L10 3" stroke="#FF6B2B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="feature-text"><strong>Transparent pricing</strong> — no surprise fees, ever</div>
          </div>
          <div class="about-feature">
            <div class="feature-check">
              <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 6L5 9L10 3" stroke="#FF6B2B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="feature-text"><strong>Ethical practices</strong> — sourced and printed responsibly</div>
          </div>
          <div class="about-feature">
            <div class="feature-check">
              <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 6L5 9L10 3" stroke="#FF6B2B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="feature-text"><strong>Always reachable</strong> — real humans, 24/7 support</div>
          </div>
          <div class="about-feature">
            <div class="feature-check">
              <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 6L5 9L10 3" stroke="#FF6B2B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="feature-text"><strong>Design assistance</strong> — we'll help perfect your artwork</div>
          </div>
        </div>
      </div>

      <div class="about-right reveal" style="transition-delay:0.1s">
        <div class="about-card">
          <div class="about-card-val">12+</div>
          <div class="about-card-label">Min. qty for bulk pricing</div>
        </div>
        <div class="about-card">
          <div class="about-card-val">5–7</div>
          <div class="about-card-label">Day standard turnaround</div>
        </div>
        <div class="about-card accent">
          <div class="about-card-val">Same day</div>
          <div class="about-card-label">Rush service available for Los Angeles orders</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cap-section">
  <div class="container">
    <div class="reveal">
      <div class="eyebrow">Our Capabilities</div>
      <h2 class="section-title">Built for every project,<br>every scale.</h2>
    </div>
    <div class="cap-grid">
      <div class="cap-card reveal">
        <span class="cap-icon">🎨</span>
        <div class="cap-name">Direct to Garment (DTG)</div>
        <div class="cap-body">Perfect for highly detailed, multi-colored designs on small batches. The ink binds directly to the fabric for a soft, premium feel with unlimited color options.</div>
      </div>
      <div class="cap-card reveal" style="transition-delay:0.08s">
        <span class="cap-icon">🖨️</span>
        <div class="cap-name">Screen Printing</div>
        <div class="cap-body">The gold standard for bulk orders. Durable, vibrant, and incredibly cost-effective for larger quantities starting at just 12 pieces.</div>
      </div>
      <div class="cap-card reveal" style="transition-delay:0.16s">
        <span class="cap-icon">🪡</span>
        <div class="cap-name">Custom Embroidery</div>
        <div class="cap-body">Elevate your brand with professional, tactile embroidery. Ideal for hats, polos, and premium outerwear that makes a lasting impression.</div>
      </div>
    </div>
  </div>
</section>

<section class="cta-band">
  <div class="container">
    <h2>Ready to make something<br>incredible?</h2>
    <p>Our team is available 24/7 for instant quotes and design assistance.</p>
    <div class="cta-band-actions">
      <button class="btn-white" data-quote-trigger onclick="openModal()">Get a Free Quote</button>
      <a href="tel:3109042655" class="btn-outline-white">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M3.7 1C3.3 1 2.5 1.3 1.9 2L1 3c-.7.7-1 2 .3 4 .7 1.2 1.7 2.6 3.1 4s2.8 2.4 4 3.1c2 1.3 3.3 1 4 .3l1-1c.7-.7 1-1.5 1-1.9 0-.2-.2-.5-.5-.7L12 9.5c-.3-.2-.6-.3-.8-.2l-1.3.4c-.3.1-.6 0-.8-.2L7.5 8l-1.5-1.6c-.2-.2-.3-.5-.2-.8L6.2 4.4c.1-.2 0-.5-.2-.8L4.4 1.5C4.2 1.2 3.9 1 3.7 1z"/></svg>
        Call (310) 904-2655
      </a>
    </div>
  </div>
</section>

<section class="faq-section" id="faq">
  <div class="container">
    <div class="reveal" style="text-align:center; margin-bottom:0">
      <div class="eyebrow">FAQ</div>
      <h2 class="section-title">Frequently asked<br>questions.</h2>
    </div>

    <div class="faq-grid">
      <div>
        <div class="faq-item open">
          <div class="faq-question">
            <span class="faq-q-text">What type of shirt can I choose?</span>
            <div class="faq-icon">+</div>
          </div>
          <div class="faq-answer">You have many brand and material options — cotton, polyester, blends, and more — as well as weight, size, and gender preferences. You may also bring your own shirts to print on.</div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span class="faq-q-text">How can I get a price quote?</span>
            <div class="faq-icon">+</div>
          </div>
          <div class="faq-answer">Click any "Get a Quote" button on the site and complete the quick form. You can also call us at (310) 904-2655 for a fast estimate — we respond within 1 business hour.</div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span class="faq-q-text">How do I order a custom shirt?</span>
            <div class="faq-icon">+</div>
          </div>
          <div class="faq-answer">Ordering starts with selecting your garment, creating or uploading your design, and choosing placement. Our team guides you through the entire process from start to finish.</div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span class="faq-q-text">What's the minimum order quantity?</span>
            <div class="faq-icon">+</div>
          </div>
          <div class="faq-answer">We have no minimum order quantity. You can order a single shirt! That said, you benefit significantly at 12+ pieces due to bulk pricing on screen printing.</div>
        </div>
      </div>

      <div>
        <div class="faq-item">
          <div class="faq-question">
            <span class="faq-q-text">Do I need to create my own design?</span>
            <div class="faq-icon">+</div>
          </div>
          <div class="faq-answer">Not at all. We accept high-resolution files in .ai, .png, .jpg, or .svg formats. We can also edit your existing design or create a custom design for you at a small cost.</div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span class="faq-q-text">How long does it take to get my shirts?</span>
            <div class="faq-icon">+</div>
          </div>
          <div class="faq-answer">Standard turnaround is 5–7 business days after artwork approval and payment. Rush orders (4 business days) are available for an additional fee. Same-day service available locally in LA.</div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span class="faq-q-text">How much is delivery?</span>
            <div class="faq-icon">+</div>
          </div>
          <div class="faq-answer">Local delivery options are available in the Los Angeles area. Final delivery cost depends on order size and location. Contact us for an exact quote including delivery.</div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span class="faq-q-text">What printing method is right for me?</span>
            <div class="faq-icon">+</div>
          </div>
          <div class="faq-answer">For bulk + simple designs: screen printing. For photo-quality or small batches: DTG. For versatility across fabrics: DTF. For premium branded items: embroidery. We'll help you choose.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="email-section">
  <div class="container">
    <h2>Get daily deals &amp; printing tips.</h2>
    <p>Subscribe for exclusive discounts and custom printing updates.</p>
    <div class="email-form">
      <input type="email" class="email-input" id="emailInput" placeholder="your@email.com">
      <button class="email-submit" id="emailSubmit">Subscribe</button>
    </div>
    <p class="email-fine">🔒 &nbsp;No spam. Unsubscribe anytime.</p>
  </div>
</div>

</Layout>

<style is:global>
  :root {
    --orange:      #FF6B2B;
    --orange-deep: #E8521A;
    --orange-soft: #FFF0E8;
    --orange-mid:  #FFD9C4;
    --white:       #FFFFFF;
    --bg:          #FAFAFA;
    --surface:     #F5F5F7;
    --border:      #E5E5EA;
    --border-soft: #F0F0F5;
    --text-primary:   #1D1D1F;
    --text-secondary: #6E6E73;
    --text-tertiary:  #8E8E93;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.07), 0 1px 4px rgba(0,0,0,0.04);
    --shadow-lg: 0 16px 48px rgba(0,0,0,0.10), 0 4px 12px rgba(0,0,0,0.05);
    --shadow-xl: 0 32px 80px rgba(0,0,0,0.14), 0 8px 24px rgba(0,0,0,0.07);
    --radius-sm: 10px;
    --radius-md: 16px;
    --radius-lg: 24px;
    --radius-xl: 32px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: 'Manrope', -apple-system, BlinkMacSystemFont, sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  .container { max-width: 1080px; margin: 0 auto; padding: 0 40px; }
  .eyebrow {
    font-size: 13px; font-weight: 600; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--orange);
    margin-bottom: 12px;
  }

  .hero {
    background: white;
    padding: 100px 0 80px;
    text-align: center;
    position: relative; overflow: hidden;
  }

  .hero-glow {
    position: absolute; top: -60px; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 400px;
    background: radial-gradient(ellipse at 50% 0%, rgba(255,107,43,0.10), transparent 70%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--orange-soft); border: 1px solid var(--orange-mid);
    color: var(--orange); padding: 6px 14px; border-radius: 100px;
    font-size: 12.5px; font-weight: 700; letter-spacing: 0.02em;
    margin-bottom: 28px;
    animation: fadeUp 0.5s ease both;
  }
  .badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--orange); animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }

  .hero h1 {
    font-size: clamp(42px, 6vw, 76px);
    font-weight: 800; line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--text-primary);
    max-width: 760px; margin: 0 auto 20px;
    animation: fadeUp 0.55s 0.05s ease both;
  }
  .hero h1 span { color: var(--orange); }

  .hero-sub {
    font-size: 19px; line-height: 1.65;
    color: var(--text-secondary); font-weight: 400;
    max-width: 520px; margin: 0 auto 44px;
    animation: fadeUp 0.55s 0.1s ease both;
  }

  .hero-actions {
    display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 0.55s 0.15s ease both;
    margin-bottom: 64px;
  }

  .btn-primary {
    background: var(--orange); color: white;
    padding: 14px 30px; border-radius: 100px;
    font-size: 16px; font-weight: 700; letter-spacing: -0.01em;
    border: none; cursor: pointer;
    transition: background 0.18s, transform 0.15s, box-shadow 0.18s;
    box-shadow: 0 4px 20px rgba(255,107,43,0.35);
  }
  .btn-primary:hover {
    background: var(--orange-deep);
    transform: scale(1.02);
    box-shadow: 0 6px 28px rgba(255,107,43,0.45);
  }

  .btn-secondary {
    background: var(--surface); color: var(--text-primary);
    padding: 14px 30px; border-radius: 100px;
    font-size: 16px; font-weight: 600;
    border: 1px solid var(--border); cursor: pointer;
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
    transition: background 0.18s, transform 0.15s;
  }
  .btn-secondary:hover { background: var(--border-soft); transform: scale(1.02); }

  .hero-stats {
    display: flex; justify-content: center; gap: 0;
    border-top: 1px solid var(--border);
    padding-top: 48px;
    animation: fadeUp 0.55s 0.22s ease both;
  }

  .hero-stat {
    padding: 0 48px;
    border-right: 1px solid var(--border);
    text-align: center;
  }
  .hero-stat:last-child { border-right: none; }

  .stat-val {
    font-size: 32px; font-weight: 800; letter-spacing: -0.04em;
    color: var(--text-primary); line-height: 1;
    margin-bottom: 5px;
  }
  .stat-val span { color: var(--orange); }
  .stat-label {
    font-size: 13px; color: var(--text-secondary); font-weight: 500;
  }

  .services-section {
    padding: 100px 0;
    background: var(--bg);
  }

  .services-header {
    text-align: center; margin-bottom: 60px;
  }

  .section-title {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 800; letter-spacing: -0.03em;
    color: var(--text-primary); line-height: 1.1;
  }

  .section-sub {
    font-size: 17px; color: var(--text-secondary);
    margin-top: 12px; font-weight: 400; line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
