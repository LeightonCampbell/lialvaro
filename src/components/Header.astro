---
interface Props {
	quoteCta?: 'link' | 'modal';
	faqHref?: string;
}

const { quoteCta = 'link', faqHref = '/#faq' } = Astro.props;
---
<nav class="site-header-nav" id="site-header-nav" aria-label="Primary">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="LiAlvaro Home">
      <img src="/brand/logo.png" alt="LiAlvaro" />
    </a>

    <div class="nav-desktop">
      <ul class="nav-links">
        <li><a href="/design-your-apparel">Design Your Apparel</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href={faqHref}>FAQ</a></li>
        <li><a href="/articles">Articles</a></li>
      </ul>

      <div class="nav-actions">
        <a href="tel:3109042655" class="btn-phone">
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M3.7 1C3.3 1 2.5 1.3 1.9 2L1 3c-.7.7-1 2 .3 4 .7 1.2 1.7 2.6 3.1 4s2.8 2.4 4 3.1c2 1.3 3.3 1 4 .3l1-1c.7-.7 1-1.5 1-1.9 0-.2-.2-.5-.5-.7L12 9.5c-.3-.2-.6-.3-.8-.2l-1.3.4c-.3.1-.6 0-.8-.2L7.5 8l-1.5-1.6c-.2-.2-.3-.5-.2-.8L6.2 4.4c.1-.2 0-.5-.2-.8L4.4 1.5C4.2 1.2 3.9 1 3.7 1z"/></svg>
          (310) 904-2655
        </a>
        {quoteCta === 'modal' ? (
          <button type="button" class="btn-cta-sm" data-quote-trigger>Get a Quote</button>
        ) : (
          <a href="/contact" class="btn-cta-sm">Get a Quote</a>
        )}
      </div>
    </div>

    <button
      type="button"
      class="nav-menu-toggle"
      id="site-nav-menu-toggle"
      aria-expanded="false"
      aria-controls="site-nav-mobile-panel"
      aria-label="Open menu"
    >
      <span class="nav-menu-burger" aria-hidden="true"></span>
    </button>
  </div>

  <div
    id="site-nav-mobile-panel"
    class="nav-mobile-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Menu"
    hidden
  >
    <ul class="nav-mobile-links">
      <li><a href="/design-your-apparel">Design Your Apparel</a></li>
      <li><a href="/about">About Us</a></li>
      <li><a href={faqHref}>FAQ</a></li>
      <li><a href="/articles">Articles</a></li>
    </ul>
    <div class="nav-mobile-actions">
      <a href="tel:3109042655" class="btn-phone btn-phone-mobile">
        <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M3.7 1C3.3 1 2.5 1.3 1.9 2L1 3c-.7.7-1 2 .3 4 .7 1.2 1.7 2.6 3.1 4s2.8 2.4 4 3.1c2 1.3 3.3 1 4 .3l1-1c.7-.7 1-1.5 1-1.9 0-.2-.2-.5-.5-.7L12 9.5c-.3-.2-.6-.3-.8-.2l-1.3.4c-.3.1-.6 0-.8-.2L7.5 8l-1.5-1.6c-.2-.2-.3-.5-.2-.8L6.2 4.4c.1-.2 0-.5-.2-.8L4.4 1.5C4.2 1.2 3.9 1 3.7 1z"/></svg>
        (310) 904-2655
      </a>
      {quoteCta === 'modal' ? (
        <button type="button" class="btn-cta-sm btn-cta-mobile" data-quote-trigger>Get a Quote</button>
      ) : (
        <a href="/contact" class="btn-cta-sm btn-cta-mobile">Get a Quote</a>
      )}
    </div>
  </div>
</nav>

<script>
  (() => {
    const nav = document.getElementById('site-header-nav');
    const toggle = document.getElementById('site-nav-menu-toggle');
    const panel = document.getElementById('site-nav-mobile-panel');
    if (!nav || !toggle || !panel) return;

    const openLabel = 'Open menu';
    const closeLabel = 'Close menu';

    function setOpen(open) {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? closeLabel : openLabel);
      nav.classList.toggle('nav-is-open', open);
      panel.hidden = !open;
      document.body.style.overflow = open ? 'hidden' : '';
    }

    toggle.addEventListener('click', () => {
      setOpen(panel.hidden);
    });

    panel.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    panel.querySelectorAll('[data-quote-trigger]').forEach((el) => {
      el.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.hidden) setOpen(false);
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 900 && !panel.hidden) setOpen(false);
    });
  })();
</script>

<style>
  .site-header-nav {
    position: sticky;
    top: 0;
    z-index: 500;
    background: rgba(250, 250, 250, 0.82);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid #f0f0f5;
    min-height: 52px;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .nav-inner {
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 40px;
    min-height: 52px;
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    box-sizing: border-box;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo img {
    height: 34px;
    width: auto;
    display: block;
  }

  .nav-desktop {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 28px;
    flex: 1;
    min-width: 0;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .nav-links a {
    font-size: 13.5px;
    font-weight: 500;
    color: #6e6e73;
    text-decoration: none;
    transition: color 0.18s;
  }

  .nav-links a:hover {
    color: #1d1d1f;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .btn-phone {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #6e6e73;
    text-decoration: none;
    transition: color 0.18s;
  }

  .btn-phone:hover {
    color: #1d1d1f;
  }

  .btn-phone svg {
    width: 13px;
    height: 13px;
  }

  .btn-cta-sm {
    background: #ff6b2b;
    color: #fff;
    padding: 8px 18px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.18s, transform 0.15s;
    letter-spacing: -0.01em;
  }

  .btn-cta-sm:hover {
    background: #e8521a;
    transform: scale(1.02);
  }

  .nav-menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    border-radius: 10px;
    color: #1d1d1f;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
  }

  .nav-menu-toggle:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .nav-menu-toggle:focus-visible {
    outline: 2px solid #ff6b2b;
    outline-offset: 2px;
  }

  /* Hamburger lines — visual weight scaled to logo (34px) bar area */
  .nav-menu-burger {
    display: block;
    position: relative;
    width: 22px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    box-shadow:
      0 -7px 0 currentColor,
      0 7px 0 currentColor;
  }

  .nav-mobile-panel {
    display: none;
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    padding: 8px 0 20px;
    background: rgba(255, 255, 255, 0.98);
    border-bottom: 1px solid #f0f0f5;
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.06);
  }

  .nav-mobile-panel:not([hidden]) {
    display: block;
  }

  .site-header-nav.nav-is-open {
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
  }

  .nav-mobile-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-mobile-links a {
    display: block;
    padding: 14px 0;
    font-size: 16px;
    font-weight: 600;
    color: #1d1d1f;
    text-decoration: none;
    border-bottom: 1px solid #f0f0f5;
    transition: color 0.15s;
  }

  .nav-mobile-links li:first-child a {
    border-top: 1px solid #f0f0f5;
  }

  .nav-mobile-links a:hover {
    color: #ff6b2b;
  }

  .nav-mobile-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 20px;
  }

  .btn-phone-mobile {
    font-size: 15px;
  }

  .btn-cta-mobile {
    width: 100%;
    justify-content: center;
    padding: 12px 20px;
  }

  @media (max-width: 900px) {
    .nav-inner {
      padding: 0 16px;
      max-width: none;
    }

    .nav-desktop {
      display: none;
    }

    .nav-menu-toggle {
      display: flex;
    }

    .nav-mobile-panel {
      padding-left: 16px;
      padding-right: 16px;
    }
  }

  @media (min-width: 901px) {
    .nav-mobile-panel {
      display: none !important;
    }
  }
</style>
