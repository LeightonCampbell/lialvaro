---
<header class="site-nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="LiAlvaro Home">
      <img src="/brand/logo.png" alt="LiAlvaro" class="logo-image" />
    </a>

    <nav class="nav-links">
      <a href="/design-your-apparel">Design Your Apparel</a>
      <a href="/about">About Us</a>
      <a href="/#faq">FAQ</a>
      <a href="/articles">Articles</a>
    </nav>

    <div class="nav-actions">
      <a href="tel:3109042655" class="btn-phone">
        <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M3.7 1C3.3 1 2.5 1.3 1.9 2L1 3c-.7.7-1 2 .3 4 .7 1.2 1.7 2.6 3.1 4s2.8 2.4 4 3.1c2 1.3 3.3 1 4 .3l1-1c.7-.7 1-1.5 1-1.9 0-.2-.2-.5-.5-.7L12 9.5c-.3-.2-.6-.3-.8-.2l-1.3.4c-.3.1-.6 0-.8-.2L7.5 8l-1.5-1.6c-.2-.2-.3-.5-.2-.8L6.2 4.4c.1-.2 0-.5-.2-.8L4.4 1.5C4.2 1.2 3.9 1 3.7 1z"/></svg>
        (310) 904-2655
      </a>
      <a href="/contact" class="btn-cta-sm">Get a Quote</a>
    </div>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 500;
    background: rgba(250,250,250,0.82);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid #f0f0f5;
    height: 52px;
    display: flex;
    align-items: center;
  }

  .nav-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
  }

  .logo-image {
    height: 34px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-links a {
    font-size: 13.5px;
    font-weight: 500;
    color: #6e6e73;
    text-decoration: none;
    transition: color 0.18s;
  }

  .nav-links a:hover {
    color: #1d1d1f;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .btn-phone {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #6e6e73;
    text-decoration: none;
    transition: color 0.18s;
  }

  .btn-phone:hover {
    color: #1d1d1f;
  }

  .btn-phone svg {
    width: 13px;
    height: 13px;
  }

  .btn-cta-sm {
    background: #ff6b2b;
    color: #fff;
    padding: 8px 18px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
  }

  .btn-cta-sm:hover {
    background: #e8521a;
  }

  @media (max-width: 900px) {
    .nav-links,
    .btn-phone {
      display: none;
    }
  }
</style>
