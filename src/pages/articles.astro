---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Articles | LiAlvaro Apparel">
  <section class="hero">
    <div class="container">
      <h1>Insights. Guides. Inspiration.</h1>
      <p>Everything you need to know about custom apparel from the experts in Los Angeles.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="articles-grid">
        <a href="/best-affordable-custom-t-shirt-printing-in-los-angeles-2026-local-guide" class="article-card">
          <div class="article-media one"></div>
          <div class="article-content">
            <div class="meta">Local Guide • 5 Min Read</div>
            <h2>Best Affordable Custom T-Shirt Printing in Los Angeles (2026 Local Guide)</h2>
            <p>Discover how to navigate the LA market to find high-quality prints without overspending.</p>
            <span class="read-more">Read Article →</span>
          </div>
        </a>

        <a href="/the-ultimate-guide-to-finding-the-perfect-place-for-your-bulk-custom-t-shirt-event-needs" class="article-card">
          <div class="article-media two"></div>
          <div class="article-content">
            <div class="meta">Event Planning • 8 Min Read</div>
            <h2>The Ultimate Guide to Finding the Perfect Place for Your Bulk Custom T-Shirt Event Needs</h2>
            <p>Learn exactly what to look for when choosing a print partner for high-volume event orders.</p>
            <span class="read-more">Read Article →</span>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 110px 0 70px;
    text-align: center;
    background: #fff;
    border-bottom: 1px solid #e5e5ea;
  }

  .hero h1 {
    font-size: clamp(40px, 6vw, 70px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 14px;
  }

  .hero p {
    max-width: 760px;
    margin: 0 auto;
    color: #6e6e73;
    font-size: 19px;
    line-height: 1.65;
  }

  .section {
    padding: 80px 0 90px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
  }

  .article-card {
    background: #101012;
    border-radius: 24px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
  }

  .article-card:hover {
    transform: translateY(-4px);
  }

  .article-media {
    aspect-ratio: 16/9;
    background-size: cover;
    background-position: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .article-media.one {
    background-image: linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)), url("/images/screenprinting.jpg");
  }

  .article-media.two {
    background-image: linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)), url("/images/dtf.jpg");
  }

  .article-content {
    padding: 22px;
  }

  .meta {
    color: #ff6b2b;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .article-content h2 {
    color: #fff;
    font-size: clamp(20px, 2.2vw, 28px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }

  .article-content p {
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .read-more {
    color: #fff;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
