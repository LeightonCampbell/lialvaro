---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Premium custom t-shirt printing and embroidery in Los Angeles. No minimums, same-day printing available." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Lialvaro Custom Apparel</title>
	</head>
	<body>
		<div class="top-bar">
			<div class="container top-bar-content">
				<p>Same-day service available in Los Angeles &nbsp;·&nbsp; Call <a href="tel:3109042655">(310) 904-2655</a> for instant help</p>
			</div>
		</div>
		<Header />
		<main class="pt-nav">
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	.top-bar {
		background: #000;
		color: #fff;
		padding: 9px 0;
		text-align: center;
	}

	.top-bar-content p {
		font-size: 12.5px;
		color: rgba(255,255,255,0.72);
		letter-spacing: 0.02em;
	}

	.top-bar-content a {
		color: #ff6b2b;
		text-decoration: none;
		font-weight: 700;
	}
</style>
