</style>

<script is:inline>
  const overlay   = document.getElementById('modalOverlay');
  const formView  = document.getElementById('modalForm');
  const successView = document.getElementById('modalSuccess');

  function openModal(service) {
    if (service) {
      document.querySelectorAll('.service-opt').forEach(o => {
        o.classList.toggle('selected', o.dataset.service === service);
      });
    }
    formView.style.display  = '';
    successView.style.display = 'none';
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    setTimeout(() => document.getElementById('fname').focus(), 320);
  }

  function closeModal() {
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  window.openModal = openModal;
  window.closeModal = closeModal;

  document.querySelectorAll('[data-quote-trigger]').forEach((el) => {
    el.addEventListener('click', (event) => {
      if (el.tagName === 'A') event.preventDefault();
      openModal();
    });
  });

  document.getElementById('modalClose').addEventListener('click', closeModal);
  document.getElementById('successClose').addEventListener('click', closeModal);

  overlay.addEventListener('click', e => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeModal();
  });

  document.getElementById('servicePicker').addEventListener('click', e => {
    const opt = e.target.closest('.service-opt');
    if (!opt) return;
    document.querySelectorAll('.service-opt').forEach(o => o.classList.remove('selected'));
    opt.classList.add('selected');
  });

  document.getElementById('modalSubmit').addEventListener('click', () => {
    const email = document.getElementById('email').value;
    const fname = document.getElementById('fname').value;
    if (!fname.trim()) {
      document.getElementById('fname').focus();
      document.getElementById('fname').style.borderColor = 'var(--orange)';
      return;
    }
    if (!email.includes('@')) {
      document.getElementById('email').focus();
      document.getElementById('email').style.borderColor = 'var(--orange)';
      return;
    }
    formView.style.display  = 'none';
    successView.style.display = 'block';
  });

  document.querySelectorAll('.faq-item').forEach(item => {
    item.querySelector('.faq-question').addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });

  const revealObserver = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('visible');
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  document.getElementById('emailSubmit').addEventListener('click', function () {
    const inp = document.getElementById('emailInput');
    if (inp.value.includes('@')) {
      this.textContent = '✓ Subscribed!';
      this.style.background = '#2a6e2a';
      inp.disabled = true;
    } else {
      inp.style.boxShadow = '0 0 0 3px rgba(255,107,43,0.25)';
      inp.focus();
    }
  });

  window.addEventListener('scroll', () => {
    const navEl = document.querySelector('.site-header-nav');
    if (navEl) {
      navEl.style.boxShadow =
        window.scrollY > 10 ? '0 1px 0 rgba(0,0,0,0.08)' : 'none';
    }
  }, { passive: true });
</script>
