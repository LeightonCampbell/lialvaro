<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-grid">
      <div class="footer-col footer-brand">
        <a href="/" class="footer-logo" aria-label="LiAlvaro Home">
          <img src="/brand/logo.png" alt="LiAlvaro" />
        </a>
        <p class="footer-tagline">Los Angeles' premier custom apparel printer. Premium quality, no minimums, same-day service.</p>
        <a href="tel:3109042655" class="footer-phone">(310) 904-2655</a>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/design-your-apparel">Screen Printing</a></li>
          <li><a href="/design-your-apparel">Direct To Garment</a></li>
          <li><a href="/design-your-apparel">Direct To Film</a></li>
          <li><a href="/design-your-apparel">Custom Embroidery</a></li>
          <li><a href="/design-your-apparel">Same-Day Printing</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About Us</a></li>
          <li><a href="/articles">Articles & Guides</a></li>
          <li><a href="/contact">Contact & Location</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/contact">Get a Free Quote</a></li>
          <li><a href="/#faq">FAQ</a></li>
          <li><a href="tel:3109042655">Call Us Now</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; 2026 LiAlvaro T-Shirt Printing. All Rights Reserved. Los Angeles, CA.</p>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1d1d1f;
    color: rgba(255, 255, 255, 0.72);
    margin-top: 72px;
  }

  .footer-inner {
    padding: 64px 0 32px;
  }

  .footer .container {
    max-width: 1080px;
    padding: 0 40px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 52px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    margin-bottom: 14px;
  }

  .footer-logo img {
    height: 40px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.65;
    max-width: 240px;
    margin-bottom: 20px;
  }

  .footer-phone {
    display: inline-flex;
    align-items: center;
    color: #ff6b2b;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer-phone:hover {
    opacity: 0.8;
  }

  .footer-col h4 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 18px;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
    padding: 0;
  }

  .footer-col a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.18s;
    font-weight: 500;
  }

  .footer-col a:hover {
    color: #fff;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-copy {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.35);
  }

  .footer-legal {
    display: flex;
    gap: 20px;
  }

  .footer-legal a {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
  }

  .footer-legal a:hover {
    color: rgba(255, 255, 255, 0.65);
  }

  @media (max-width: 980px) {
    .footer .container {
      padding: 0 22px;
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
