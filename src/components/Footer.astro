<footer class="footer">
  <div class="footer-shell">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="LiAlvaro Home">
          <img src="/brand/footer-logo.png" alt="LiAlvaro" />
        </a>
        <p class="footer-tagline">
          Los Angeles&rsquo; premier custom apparel printer. Premium quality, no minimums, same-day service.
        </p>
        <a href="tel:3109042655" class="footer-phone">
          <svg class="footer-phone-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" width="14" height="14">
            <path d="M3.7 1C3.3 1 2.5 1.3 1.9 2L1 3c-.7.7-1 2 .3 4 .7 1.2 1.7 2.6 3.1 4s2.8 2.4 4 3.1c2 1.3 3.3 1 4 .3l1-1c.7-.7 1-1.5 1-1.9 0-.2-.2-.5-.5-.7L12 9.5c-.3-.2-.6-.3-.8-.2l-1.3.4c-.3.1-.6 0-.8-.2L7.5 8l-1.5-1.6c-.2-.2-.3-.5-.2-.8L6.2 4.4c.1-.2 0-.5-.2-.8L4.4 1.5C4.2 1.2 3.9 1 3.7 1z"/>
          </svg>
          <span class="footer-phone-text">(310) 904-2655</span>
        </a>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/design-your-apparel">Screen Printing</a></li>
          <li><a href="/design-your-apparel">Direct to Garment</a></li>
          <li><a href="/design-your-apparel">Direct to Film</a></li>
          <li><a href="/design-your-apparel">Custom Embroidery</a></li>
          <li><a href="/design-your-apparel">Same-Day Printing</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About Us</a></li>
          <li><a href="/articles">Articles &amp; Guides</a></li>
          <li><a href="/contact">Contact &amp; Location</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/contact" data-quote-trigger>Get a Free Quote</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="tel:3109042655">Call Us Now</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; 2026 LiAlvaro T-Shirt Printing. All Rights Reserved. Los Angeles, CA.</p>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #000;
    color: rgba(255, 255, 255, 0.72);
    margin-top: 0;
  }

  .footer-shell {
    max-width: 1080px;
    margin: 0 auto;
    padding: 72px 40px 36px;
    box-sizing: border-box;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) repeat(3, minmax(0, 1fr));
    column-gap: 56px;
    row-gap: 40px;
    align-items: start;
    margin-bottom: 48px;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: 18px;
    line-height: 0;
  }

  .footer-logo img {
    height: 40px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
    max-width: 260px;
    margin: 0 0 22px;
  }

  .footer-phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #ff6b2b;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer-phone:hover {
    opacity: 0.85;
  }

  .footer-phone-icon {
    flex-shrink: 0;
    color: #ff6b2b;
  }

  .footer-col h4 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.38);
    margin: 2px 0 20px;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0;
    padding: 0;
  }

  .footer-col a {
    font-size: 14px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    transition: color 0.18s;
    font-weight: 500;
  }

  .footer-col a:hover {
    color: #fff;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-copy {
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.38);
    margin: 0;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .footer-legal a {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.38);
    text-decoration: none;
  }

  .footer-legal a:hover {
    color: rgba(255, 255, 255, 0.65);
  }

  @media (max-width: 980px) {
    .footer-shell {
      padding: 56px 22px 32px;
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: 40px;
      row-gap: 36px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 700px) {
    .footer-shell {
      padding: 48px 16px 28px;
    }

    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
