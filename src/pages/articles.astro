---
import Layout from "../layouts/Layout.astro";
import ArticleCard from "../components/ArticleCard.astro";
---

<Layout title="Articles | LiAlvaro Apparel">
  <section class="hero">
    <div class="container">
      <h1>Insights. Guides. Inspiration.</h1>
      <p>Everything you need to know about custom apparel from the experts in Los Angeles.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="articles-grid">
        {
          [
            {
              href: "/best-affordable-custom-t-shirt-printing-in-los-angeles-2026-local-guide",
              imageUrl: "/images/screenprinting.jpg",
              meta: "Local Guide • 5 Min Read",
              title: "Best Affordable Custom T-Shirt Printing in Los Angeles (2026 Local Guide)",
              excerpt: "Discover how to navigate the LA market to find high-quality prints without overspending.",
            },
            {
              href: "/the-ultimate-guide-to-finding-the-perfect-place-for-your-bulk-custom-t-shirt-event-needs",
              imageUrl: "/images/dtf.jpg",
              meta: "Event Planning • 8 Min Read",
              title: "The Ultimate Guide to Finding the Perfect Place for Your Bulk Custom T-Shirt Event Needs",
              excerpt: "Learn exactly what to look for when choosing a print partner for high-volume event orders.",
            },
          ].map((a) => (
            <ArticleCard
              href={a.href}
              imageUrl={a.imageUrl}
              meta={a.meta}
              title={a.title}
              excerpt={a.excerpt}
            />
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 110px 0 70px;
    text-align: center;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    border-bottom: 1px solid var(--border-soft);
  }

  .hero h1 {
    font-size: clamp(40px, 6vw, 70px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 14px;
    color: var(--text-primary);
  }

  .hero p {
    max-width: 760px;
    margin: 0 auto;
    color: var(--text-secondary);
    font-size: 19px;
    line-height: 1.65;
  }

  .section {
    padding: 80px 0 90px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  @media (max-width: 1200px) {
    .articles-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 1024px) {
    .articles-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
