FAQ STYLES BACKUP
=================

.faq-section {
  padding-top: 3.5rem;
  background: #ffffff;
}
.faq-title {
  background: #000;
  color: #fff;
  text-align: center;
  padding: 1.1rem 1rem;
  margin: 0 0 0.8rem;
  width: 100vw;
  margin-left: calc(50% - 50vw);
  font-size: clamp(1.45rem, 2.4vw, 1.95rem);
}
.faq-list {
  background: #ffffff;
  max-width: 620px;
  margin: 0 auto;
}
.faq-item {
  border-bottom: 1px solid #d7d7d9;
  padding: 0;
}
.faq-item summary {
  list-style: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.18rem 0.35rem;
  color: #161616;
  font-size: 0.95rem;
  font-weight: 600;
}
.faq-item summary::-webkit-details-marker {
  display: none;
}
.faq-icon {
  color: #cf4c1b;
  width: 14px;
  height: 14px;
  position: relative;
  flex-shrink: 0;
}
.faq-icon::before,
.faq-icon::after {
  content: "";
  position: absolute;
  background: currentColor;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}
.faq-icon::before {
  width: 10px;
  height: 1px;
}
.faq-icon::after {
  width: 1px;
  height: 10px;
}
.faq-item[open] .faq-icon::after {
  opacity: 0;
}
.faq-item p {
  margin: 0;
  padding: 0 0.35rem 1.05rem;
  color: #222;
  font-size: 0.9rem;
  line-height: 1.45;
  max-width: 100%;
}
.faq-answer {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 260ms ease;
}
.faq-answer p {
  overflow: hidden;
}
.faq-item[open] .faq-answer {
  grid-template-rows: 1fr;
}
