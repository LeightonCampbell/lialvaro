---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Design Your Apparel | LiAlvaro Apparel">
  <section class="hero">
    <div class="container">
      <h1>What would you like to design today?</h1>
      <p>Tell us about your project and we will recommend the best print method, timeline, and pricing for your goals.</p>
    </div>
  </section>

  <section class="section">
    <div class="container layout-grid">
      <article class="form-card">
        <h2>Project request</h2>
        <p class="sub">Share your vision, quantities, and timeline. Our team will follow up with a tailored design and production plan.</p>

        <form id="designRequestForm" action="#" method="post">
          <div class="row">
            <label>
              Full Name
              <input type="text" name="name" required />
            </label>
            <label>
              Email Address
              <input type="email" name="email" required />
            </label>
          </div>

          <div class="row">
            <label>
              Phone Number
              <input type="tel" name="phone" placeholder="(310) 000-0000" />
            </label>
            <label>
              Business / Brand Name
              <input type="text" name="brand" />
            </label>
          </div>

          <fieldset class="checks-group">
            <legend>What would you like to design?</legend>
            <div class="checks">
              <label><input type="checkbox" name="items" value="T-Shirts" />T-Shirts</label>
              <label><input type="checkbox" name="items" value="Hoodies" />Hoodies</label>
              <label><input type="checkbox" name="items" value="Hats" />Hats</label>
              <label><input type="checkbox" name="items" value="Other" />Other</label>
            </div>
          </fieldset>

          <div class="row">
            <label>
              Preferred Print Method
              <select name="method">
                <option value="">Select one</option>
                <option>Screen Printing</option>
                <option>Direct To Garment (DTG)</option>
                <option>Direct To Film (DTF)</option>
                <option>Embroidery</option>
                <option>Not sure yet</option>
              </select>
            </label>
            <label>
              Estimated Quantity
              <select name="quantity">
                <option value="">Select one</option>
                <option>1-11 pieces</option>
                <option>12-24 pieces</option>
                <option>25-49 pieces</option>
                <option>50-99 pieces</option>
                <option>100+ pieces</option>
              </select>
            </label>
          </div>

          <div class="row">
            <label>
              Number of print colors
              <select name="colors">
                <option value="">Select one</option>
                <option>1 Color</option>
                <option>2 Colors</option>
                <option>3 Colors</option>
                <option>4 Colors</option>
                <option>5 Colors</option>
                <option>More than 5 colors</option>
              </select>
            </label>
            <label>
              Needed By
              <input type="date" name="deadline" />
            </label>
          </div>

          <label>
            Project details
            <textarea name="details" placeholder="Tell us your design goals, garment preferences, sizing, placements, and any special notes." required></textarea>
          </label>

          <button type="submit" class="submit">Submit Design Request</button>
          <p class="success" id="successMsg">Thanks! Your request has been submitted. Our team will contact you shortly.</p>
        </form>
      </article>

      <aside class="help-card">
        <h3>What happens next?</h3>
        <p>We review your project details and respond with recommendations based on timeline, fabric, print complexity, and budget.</p>
        <ul class="bullet-list">
          <li>Method recommendation (Screen, DTG, DTF, or Embroidery)</li>
          <li>Design support and artwork prep guidance</li>
          <li>Timeline and production plan</li>
          <li>Transparent quote with no hidden fees</li>
        </ul>
        <div class="callout">Need it fast? Ask about same-day and rush production options for Los Angeles projects.</div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("designRequestForm");
  const successMsg = document.getElementById("successMsg");
  if (form) {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      successMsg?.classList.add("show");
      form.reset();
    });
  }
</script>

<style>
  .hero {
    padding: 110px 0 72px;
    text-align: center;
    background: #fff;
    border-bottom: 1px solid #e5e5ea;
  }

  .hero h1 {
    font-size: clamp(36px, 6vw, 68px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    margin-bottom: 14px;
  }

  .hero p {
    max-width: 760px;
    margin: 0 auto;
    color: #6e6e73;
    font-size: 19px;
    line-height: 1.65;
  }

  .section {
    padding: 76px 0 94px;
  }

  .layout-grid {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: 22px;
    align-items: start;
  }

  .form-card,
  .help-card {
    background: #fff;
    border: 1px solid #f0f0f5;
    border-radius: 32px;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
    padding: 30px;
  }

  .form-card h2 {
    font-size: clamp(30px, 4vw, 42px);
    letter-spacing: -0.025em;
    margin-bottom: 10px;
  }

  .sub {
    color: #6e6e73;
    font-size: 15.5px;
    line-height: 1.7;
    margin-bottom: 22px;
  }

  form {
    display: grid;
    gap: 16px;
  }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  label {
    display: grid;
    gap: 7px;
    font-size: 12.5px;
    font-weight: 700;
    color: #53535a;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1.5px solid #e5e5ea;
    border-radius: 12px;
    padding: 12px 14px;
    font-family: inherit;
    font-size: 14.5px;
    color: #1d1d1f;
    background: #f7f7f8;
    outline: none;
  }

  textarea {
    min-height: 108px;
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: #ff6b2b;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(255, 107, 43, 0.14);
  }

  .checks {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin-top: 2px;
  }

  .checks-group {
    border: 0;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 7px;
  }

  .checks-group legend {
    font-size: 12.5px;
    font-weight: 700;
    color: #53535a;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 0;
  }

  .checks label {
    text-transform: none;
    letter-spacing: 0;
    font-size: 14px;
    font-weight: 600;
    color: #1d1d1f;
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1.5px solid #e5e5ea;
    background: #f7f7f8;
    border-radius: 12px;
    padding: 10px 12px;
  }

  .checks input[type="checkbox"] {
    width: 16px;
    height: 16px;
    padding: 0;
  }

  .submit {
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #22856c;
    color: #fff;
    border: 0;
    border-radius: 999px;
    padding: 13px 26px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    width: fit-content;
  }

  .submit:hover {
    background: #1b6f5a;
  }

  .success {
    margin-top: 14px;
    color: #1f7a62;
    font-weight: 700;
    display: none;
  }

  .success.show {
    display: block;
  }

  .help-card h3 {
    font-size: 26px;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .help-card p {
    color: #6e6e73;
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .bullet-list {
    list-style: none;
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
  }

  .bullet-list li {
    color: #6e6e73;
    line-height: 1.6;
    padding-left: 20px;
    position: relative;
  }

  .bullet-list li::before {
    content: "•";
    color: #ff6b2b;
    position: absolute;
    left: 0;
    top: 0;
    font-weight: 800;
  }

  .callout {
    margin-top: 18px;
    padding: 14px 16px;
    border-radius: 14px;
    background: #fff3ec;
    border: 1px solid #ffd7c2;
    color: #7a3a22;
    font-size: 14px;
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .layout-grid {
      grid-template-columns: 1fr;
    }
    .row {
      grid-template-columns: 1fr;
    }
    .checks {
      grid-template-columns: 1fr;
    }
  }
</style>
